<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/pink_light"
        app:title="@string/add_cat_title"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Cat Photo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/img_cat_photo"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@drawable/ic_cat_placeholder"
                    app:civ_border_width="3dp"
                    app:civ_border_color="@color/pink_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pick_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/pick_photo"
                    style="@style/Widget.CatCare.Button.Outline"
                    app:icon="@drawable/ic_camera" />
            </LinearLayout>

            <!-- Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/cat_name_hint"
                android:layout_marginBottom="14dp"
                style="@style/Widget.CatCare.TextInput">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cat_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLength="30" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Breed -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/cat_breed_hint"
                android:layout_marginBottom="14dp"
                style="@style/Widget.CatCare.TextInput">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_cat_breed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:maxLength="40" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Age + Weight Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/cat_age_hint"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.CatCare.TextInput">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_cat_age"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/cat_weight_hint"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.CatCare.TextInput">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_cat_weight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Gender -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cat_gender"
                style="@style/TextAppearance.CatCare.SectionHeader"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rg_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb_male"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/gender_male"
                    android:textColor="@color/text_primary"
                    android:checked="true" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb_female"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/gender_female"
                    android:textColor="@color/text_primary" />

            </RadioGroup>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_cat"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save_cat"
                style="@style/Widget.CatCare.Button" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>