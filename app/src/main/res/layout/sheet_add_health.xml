<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/bg_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Health Entry 💊"
        style="@style/TextAppearance.CatCare.Title"
        android:layout_marginBottom="16dp" />

    <!-- Entry Type Chips -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/health_type_hint"
        style="@style/TextAppearance.CatCare.SectionHeader"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_entry_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_checkup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Checkup"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:checked="true" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_symptom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Symptom"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_vaccine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Vaccine"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rb_general"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="General"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

    </RadioGroup>

    <!-- Date Picker -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_selected_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:text="📅 Today" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick Date"
            style="@style/Widget.CatCare.Button.Outline" />

    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/health_weight_hint"
        android:layout_marginBottom="12dp"
        style="@style/Widget.CatCare.TextInput">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_health_weight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/health_notes_hint"
        android:layout_marginBottom="20dp"
        style="@style/Widget.CatCare.TextInput">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_health_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_health"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/save"
        style="@style/Widget.CatCare.Button"
        app:backgroundTint="@color/mint" />

</LinearLayout>