<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CatCare" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/pink_primary</item>
        <item name="colorPrimaryVariant">@color/pink_soft</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/peach_primary</item>
        <item name="colorSecondaryVariant">@color/peach_dark</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_main</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/pink_light</item>
        <item name="android:navigationBarColor">@color/bg_card</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="editTextColor">@color/text_primary</item>
        <item name="android:spinnerItemStyle">@style/Widget.CatCare.SpinnerItem</item>
        <item name="android:dropDownListViewStyle">@style/Widget.CatCare.SpinnerDropDown</item>
    </style>

    <!-- Button -->
    <style name="Widget.CatCare.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pink_primary</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <style name="Widget.CatCare.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/pink_primary</item>
        <item name="android:textColor">@color/pink_primary</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Cards -->
    <style name="Widget.CatCare.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.CatCare.Card.Pink" parent="Widget.CatCare.Card">
        <item name="cardBackgroundColor">@color/pink_light</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.CatCare.Card.Peach" parent="Widget.CatCare.Card">
        <item name="cardBackgroundColor">@color/peach_light</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- TextInput -->
    <style name="Widget.CatCare.TextInput"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/pink_soft</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
    </style>

    <style name="TextAppearance.CatCare" parent="TextAppearance.MaterialComponents.Body1" />

    <style name="TextAppearance.CatCare.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.CatCare.Subtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.CatCare.SectionHeader" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/pink_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.CatCare.SpinnerItem" parent="Widget.AppCompat.TextView.SpinnerItem">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.CatCare.SpinnerDropDown" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="CatCare.DatePickerDialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:textColorPrimary">#4A1942</item>
        <item name="android:textColor">#4A1942</item>
        <item name="colorAccent">#F48FB1</item>
        <item name="android:buttonBarButtonStyle">@style/CatCare.DialogButton</item>
    </style>

    <style name="CatCare.DialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#F48FB1</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>